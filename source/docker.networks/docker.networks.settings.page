<?php
$cfgPath = '/boot/config/plugins/docker.networks/docker.networks.cfg';
$defaultCfgPath = '/usr/local/emhttp/plugins/docker.networks/default.cfg';
$validLocations = ['Docker', 'Tools', 'Tab'];

// Strip legacy #-comments before parsing so a dirty cfg never causes a fatal ini error.
function dockerNetworksSettingsLoadCfg(string $path): array {
    $raw = @file_get_contents($path);
    if ($raw === false) return [];
    $sanitized = preg_replace('/^#[^\n]*(\n|$)/m', '', $raw);
    $parsed = @parse_ini_string((string)$sanitized, false, INI_SCANNER_RAW);
    return is_array($parsed) ? $parsed : [];
}

  function dockerNetworksSettingsCfgBool(array $cfg, string $key, bool $default = false): bool {
    if (!isset($cfg[$key])) {
      return $default;
    }

    $value = strtolower(trim((string)$cfg[$key], " \t\n\r\0\x0B\"'"));
    return in_array($value, ['1', 'true', 'yes', 'on', 'preserve', 'enabled'], true);
  }

// Merge default.cfg + user cfg — same semantics as parse_plugin_cfg().
$cfg = file_exists($defaultCfgPath) ? dockerNetworksSettingsLoadCfg($defaultCfgPath) : [];
if (file_exists($cfgPath)) {
    $cfg = array_replace($cfg, dockerNetworksSettingsLoadCfg($cfgPath));
}

$currentLocation = (string)($cfg['MENU_LOCATION'] ?? 'Docker');
if (!in_array($currentLocation, $validLocations, true)) {
    $currentLocation = 'Docker';
}
$currentDashboardTileEnabled = dockerNetworksSettingsCfgBool($cfg, 'DASHBOARD_TILE_ENABLED', true);
$currentXmlTemplatePersist = dockerNetworksSettingsCfgBool($cfg, 'XML_TEMPLATE_PERSIST', false);
$currentDebugToLog = dockerNetworksSettingsCfgBool($cfg, 'DEBUG_TO_LOG', false);

$statusMsg  = '';
$statusType = 'success'; // 'success' | 'error'

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $requested = isset($_POST['MENU_LOCATION']) ? trim((string)$_POST['MENU_LOCATION']) : 'Docker';
  $requestedDashboardTileEnabled = isset($_POST['DASHBOARD_TILE_ENABLED']) && (string)$_POST['DASHBOARD_TILE_ENABLED'] === '1';
  $requestedXmlTemplatePersist = isset($_POST['XML_TEMPLATE_PERSIST']) && (string)$_POST['XML_TEMPLATE_PERSIST'] === '1';
  $requestedDebugToLog = isset($_POST['DEBUG_TO_LOG']) && (string)$_POST['DEBUG_TO_LOG'] === '1';
    if (!in_array($requested, $validLocations, true)) {
        $requested = 'Docker';
    }

    // Merge with existing parsed values; write clean key=value only — no comments.
    $existing = file_exists($defaultCfgPath) ? dockerNetworksSettingsLoadCfg($defaultCfgPath) : [];
    if (file_exists($cfgPath)) {
        $existing = array_replace($existing, dockerNetworksSettingsLoadCfg($cfgPath));
    }
    $existing['MENU_LOCATION'] = $requested;
    $existing['DASHBOARD_TILE_ENABLED'] = $requestedDashboardTileEnabled ? '1' : '0';
    $existing['XML_TEMPLATE_PERSIST'] = $requestedXmlTemplatePersist ? '1' : '0';
    $existing['DEBUG_TO_LOG'] = $requestedDebugToLog ? 'true' : 'false';

    $lines = [];
    foreach ($existing as $k => $v) {
        $lines[] = $k . '="' . addcslashes((string)$v, '"\\') . '"';
    }

    $cfgDir = dirname($cfgPath);
    if (!is_dir($cfgDir)) {
        @mkdir($cfgDir, 0755, true);
    }
    $tmpPath = $cfgPath . '.tmp';
    $written = @file_put_contents($tmpPath, implode("\n", $lines) . "\n") !== false;
    if ($written) {
        $written = @rename($tmpPath, $cfgPath);
        if (!$written) {
            @unlink($tmpPath);
        }
    }
    if ($written) {
        $currentLocation = $requested;
      $currentDashboardTileEnabled = $requestedDashboardTileEnabled;
      $currentXmlTemplatePersist = $requestedXmlTemplatePersist;
      $currentDebugToLog = $requestedDebugToLog;
        $statusMsg = 'Settings saved. Refresh the browser to apply the new menu placement.';
    } else {
        $statusType = 'error';
        $statusMsg  = 'Could not write config: ' . htmlspecialchars($cfgPath, ENT_QUOTES, 'UTF-8');
    }
}
?>

<link rel="stylesheet" type="text/css" href="/usr/local/emhttp/plugins/docker.networks/sheets/DockerNetworks.css" />

<div class="title">
  <span class="left"><i class="fa fa-sitemap icon"></i>_(Display)_</span>
</div>

<form method="post" action="" id="dn-settings-form">

  <dl>
    <dt>_(Menu Placement)_:</dt>
    <dd>
      <select name="MENU_LOCATION" id="MENU_LOCATION">
        <option value="Docker" <?= $currentLocation === 'Docker' ? 'selected' : '' ?>>_(Docker tab)_</option>
        <option value="Tools"  <?= $currentLocation === 'Tools'  ? 'selected' : '' ?>>_(Tools tab)_</option>
        <option value="Tab"    <?= $currentLocation === 'Tab'    ? 'selected' : '' ?>>_(Own top-level tab)_</option>
      </select>
      <blockquote class="inline_help">
        Choose where the Docker Networks page appears in the Unraid navigation.
        After saving, refresh the browser to see the change.<br>
        The entry is hidden automatically when Docker is stopped.
      </blockquote>
    </dd>
  </dl>

  <dl>
    <dt>_(Dashboard Tile)_:</dt>
    <dd>
      <label>
        <input type="checkbox" name="DASHBOARD_TILE_ENABLED" value="1" <?= $currentDashboardTileEnabled ? 'checked' : '' ?>>
        _(Show Docker Networks tile on the Dashboard)_
      </label>
      <blockquote class="inline_help">
        Enabled by default. Disable to hide the dashboard tile entirely.
      </blockquote>
    </dd>
  </dl>

  <dl>
    <dt>_(Template XML Persistence)_:</dt>
    <dd>
      <label>
        <input type="checkbox" name="XML_TEMPLATE_PERSIST" value="1" <?= $currentXmlTemplatePersist ? 'checked' : '' ?>>
        _(Allow Docker Networks to edit container template Post Arguments for persistent network attach)_
      </label>
      <blockquote class="inline_help">
        Disabled by default for safety. When enabled, network connect/disconnect actions can update
        <code>/boot/config/plugins/dockerMan/templates-user/my-*.xml</code> so additional network attachments persist after Docker/server restart.
      </blockquote>
    </dd>
  </dl>

  <dl>
    <dt>_(Debug Mode)_:</dt>
    <dd>
      <label>
        <input type="checkbox" name="DEBUG_TO_LOG" value="1" <?= $currentDebugToLog ? 'checked' : '' ?>>
        _(Enable debug-level syslog entries for Docker Networks)_
      </label>
      <blockquote class="inline_help">
        Disabled by default. When enabled, additional debug logs are written via syslog
        with the <code>docker.networks</code> tag to help diagnose behavior.
      </blockquote>
    </dd>
  </dl>

  <dl>
    <dt></dt>
    <dd>
      <input type="submit" value="_(Apply)_" class="orange-button">
      &nbsp;<span id="dn-status" style="display:none;"></span>
    </dd>
  </dl>

</form>

<script>
(function () {
  <?php if ($statusMsg !== ''): ?>
  var msg  = <?= json_encode($statusMsg) ?>;
  var type = <?= json_encode($statusType) ?>;
  var el   = document.getElementById('dn-status');
  if (el) {
    el.textContent = msg;
    el.style.color  = (type === 'error') ? 'var(--error-color, #e25555)' : 'var(--success-color, #5cb85c)';
    el.style.display = 'inline';
  }
  <?php endif; ?>
}());
</script>
