Author="mstrhakr"
Type="xmenu"
Menu="Utilities"
Lock="true"
Title="Docker Networks Settings"
Icon="sitemap"
---
<?php
$cfgPath = '/boot/config/plugins/docker.networks/docker.networks.cfg';
$defaultCfgPath = '/usr/local/emhttp/plugins/docker.networks/default.cfg';
$validLocations = ['Docker', 'Tools', 'Tab'];

$cfg = file_exists($cfgPath) ? (@parse_ini_file($cfgPath) ?: []) : [];
$currentLocation = (string)($cfg['MENU_LOCATION'] ?? 'Docker');
if (!in_array($currentLocation, $validLocations, true)) {
    $currentLocation = 'Docker';
}

$statusMessage = '';
$statusClass = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $requested = isset($_POST['MENU_LOCATION']) ? trim((string)$_POST['MENU_LOCATION']) : 'Docker';
    if (!in_array($requested, $validLocations, true)) {
        $requested = 'Docker';
    }

    // Read existing cfg values (parsed, no comments) then merge with new value.
    $existing = file_exists($cfgPath) ? (@parse_ini_file($cfgPath) ?: []) : [];
    if (empty($existing) && file_exists($defaultCfgPath)) {
        $existing = @parse_ini_file($defaultCfgPath) ?: [];
    }
    $existing['MENU_LOCATION'] = $requested;

    // Write clean key=value pairs only — no comments, safe for parse_ini_file on all PHP versions.
    $lines = [];
    foreach ($existing as $key => $value) {
        $lines[] = $key . '="' . addcslashes((string)$value, '"\\') . '"';
    }
    $updated = implode("\n", $lines) . "\n";

    if (@file_put_contents($cfgPath, $updated) !== false) {
        $currentLocation = $requested;
        $statusMessage = 'Settings saved. Refresh the browser to see menu placement change.';
        $statusClass = 'notice success';
    } else {
        $statusMessage = 'Unable to write config file: ' . htmlspecialchars($cfgPath, ENT_QUOTES, 'UTF-8');
        $statusClass = 'notice error';
    }
}
?>
<div class="docker-networks-settings" style="max-width:760px;">
  <h2>Docker Networks Settings</h2>

  <?php if ($statusMessage !== ''): ?>
    <div class="<?= $statusClass ?>" style="margin:10px 0; padding:10px; border-radius:4px;">
      <?= htmlspecialchars($statusMessage, ENT_QUOTES, 'UTF-8') ?>
    </div>
  <?php endif; ?>

  <form method="post" action="">
    <dl>
      <dt>Menu Placement:</dt>
      <dd>
        <select name="MENU_LOCATION" id="MENU_LOCATION">
          <option value="Docker" <?= $currentLocation === 'Docker' ? 'selected' : '' ?>>Docker tab (current default)</option>
          <option value="Tools" <?= $currentLocation === 'Tools' ? 'selected' : '' ?>>Tools tab</option>
          <option value="Tab" <?= $currentLocation === 'Tab' ? 'selected' : '' ?>>Own top-level tab</option>
        </select>
      </dd>
      <dd style="margin-top:8px; opacity:0.85;">
        Save then refresh your browser. If Docker service is stopped, the page entry stays hidden.
      </dd>
      <dd style="margin-top:16px;">
        <input type="submit" class="button" value="Save Settings">
      </dd>
    </dl>
  </form>
</div>
